// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// --- Main User Model (Represents You) ---
model User {
  id              Int           @id @default(autoincrement())
  name            String
  email           String        @unique
  headline        String?       // e.g., "Backend Developer specializing in Python & PostgreSQL"
  bio             String?
  avatar          String?       // URL to avatar image
  
  // Relations to portfolio sections
  experiences     Experience[]
  projects        Project[]
  education       Education[]
  certifications  Certification[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// --- Experience Model ---
model Experience {
  id          Int       @id @default(autoincrement())
  userId      Int
  title       String    // e.g., "Software Engineer"
  company     String
  startDate   DateTime
  endDate     DateTime? // Nullable for current roles
  description String?   // Rich text descriptions of responsibilities
  shortDescription String? // Bullet point summary
  isCurrently Boolean   @default(false)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

// --- Education Model (NEW) ---
model Education {
  id          Int       @id @default(autoincrement())
  userId      Int
  school      String    // e.g., "American International University-Bangladesh"
  degree      String    // e.g., "Bachelor of Science"
  field       String    // e.g., "Computer Science"
  startDate   DateTime
  endDate     DateTime?
  description String?
  gpa         String?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

// --- Project Model (Can cover General and Research) ---
model Project {
  id          Int       @id @default(autoincrement())
  userId      Int
  title       String
  description String
  slug        String    @unique // For dynamic routes like /projects/[slug]
  content     String?   // MDX content for detailed case study
  isResearch  Boolean   @default(false) // Differentiates research vs. general projects
  technologies String[] // Stores technologies used (e.g., ["React", "Prisma", "PostgreSQL"])
  demoLink    String?
  githubLink  String?
  thumbnail   String?   // URL to project thumbnail/cover image
  dateCompleted DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([slug])
}

// --- Certification Model ---
model Certification {
  id          Int       @id @default(autoincrement())
  userId      Int
  name        String    // e.g., "AWS Certified Developer"
  issuer      String    // e.g., "Amazon Web Services"
  dateEarned  DateTime
  credentialUrl String?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}